<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0F1F3D;--amber:#E8A838;--cream:#F9F7F2;--white:#fff;
  --border:#D4CFC6;--text:#1A1A2E;--text-muted:#6B7280;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter',sans-serif;background:var(--cream);color:var(--text);}
nav{background:var(--navy);padding:18px 32px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'Instrument Serif',serif;font-size:22px;color:#fff;text-decoration:none;}
.logo span{color:var(--amber);}
.nav-links{display:flex;gap:24px;}
.nav-link{font-size:13px;color:rgba(255,255,255,0.55);text-decoration:none;}
.nav-link:hover{color:#fff;}
.hero{background:var(--navy);padding:56px 24px;text-align:center;}
.hero-eyebrow{display:inline-block;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--amber);background:rgba(232,168,56,0.12);padding:5px 12px;border-radius:999px;margin-bottom:16px;}
.hero h1{font-family:'Instrument Serif',serif;font-size:clamp(26px,5vw,38px);color:#fff;margin-bottom:10px;}
.hero p{font-size:15px;color:rgba(255,255,255,0.6);max-width:520px;margin:0 auto;line-height:1.6;}
.filters{max-width:900px;margin:0 auto;padding:32px 24px 0;display:flex;gap:10px;flex-wrap:wrap;justify-content:center;}
.filter-pill{font-size:13px;padding:7px 16px;border-radius:999px;border:1.5px solid var(--border);background:var(--white);color:var(--text-muted);text-decoration:none;cursor:pointer;}
.filter-pill.active,.filter-pill:hover{border-color:var(--navy);color:var(--navy);}
.grid{max-width:900px;margin:0 auto;padding:32px 24px 64px;display:grid;grid-template-columns:1fr 1fr;gap:20px;}
@media(max-width:600px){.grid{grid-template-columns:1fr;}}
.card{background:var(--white);border:1.5px solid var(--border);border-radius:14px;padding:24px;text-decoration:none;display:block;transition:all 0.2s;}
.card:hover{border-color:var(--navy);transform:translateY(-2px);box-shadow:0 6px 20px rgba(15,31,61,0.08);}
.card-tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--amber);background:rgba(232,168,56,0.1);padding:3px 9px;border-radius:999px;margin-bottom:12px;}
.card-title{font-family:'Instrument Serif',serif;font-size:19px;color:var(--navy);margin-bottom:8px;line-height:1.3;}
.card-desc{font-size:13px;color:var(--text-muted);line-height:1.6;margin-bottom:14px;}
.card-date{font-size:12px;color:var(--text-muted);}
.empty{max-width:900px;margin:0 auto;padding:64px 24px;text-align:center;color:var(--text-muted);font-size:14px;}
footer{background:var(--navy);padding:32px;text-align:center;}
.footer-logo{font-family:'Instrument Serif',serif;font-size:20px;color:#fff;margin-bottom:8px;}
.footer-logo span{color:var(--amber);}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/index.html">Mone<span>tools</span></a>
  <div class="nav-links">
    <a class="nav-link" href="/index.html">Home</a>
    <a class="nav-link" href="/blog/">Blog</a>
  </div>
</nav>

<div class="hero">
  <span class="hero-eyebrow">Free Guides</span>
  <h1>{{ title }}</h1>
  <p>{{ description }}</p>
</div>

{% set posts = collections.blog | reverse %}
{% if posts.length > 0 %}
<div class="grid">
  {% for post in posts %}
  <a class="card" href="{{ post.url }}">
    {% if post.data.audience %}<span class="card-tag">{{ post.data.audience }}</span>{% endif %}
    <div class="card-title">{{ post.data.title }}</div>
    <div class="card-desc">{{ post.data.description }}</div>
    <div class="card-date">{{ post.data.date | readableDate }}</div>
  </a>
  {% endfor %}
</div>
{% else %}
<div class="empty">No articles published yet — check back soon.</div>
{% endif %}

<footer>
  <div class="footer-logo">Mone<span>tools</span></div>
</footer>
</body>
</html>
